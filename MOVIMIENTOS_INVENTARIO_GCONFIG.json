{
  "engine": "chartjs",
  "chartType": "bar",
  "options": {
    "legend": true,
    "stacked": true,
    "legendPosition": "bottom"
  },
  "palette": [
    "#9085E9",
    "#E985AC",
    "#DEE985",
    "#85E9C2",
    "#D0CDEA"
  ],
  "chart": {
    "type": "bar",
    "stacked": true,
    "responsive": true,
    "maintainAspectRatio": false
  },
  "mapping": {
    "label": "LabelTitle",
    "value": "Value1",
    "series": "SeriesTitle",
    "labelId": "LabelID",
    "labelTitle": "LabelTitle",
    "seriesId": "SeriesID",
    "seriesTitle": "SeriesTitle",
    "valueField": "Value1",
    "amountField": "Value2"
  },
  "sorting": {
    "labelsBy": "LabelID",
    "seriesBy": "SeriesID"
  },
  "axes": {
    "xTitle": "Tipo de movimiento",
    "yTitle": "Valor (MXN)",
    "yBeginAtZero": true,
    "yDecimals": 2
  },
  "tooltip": {
    "showAmount": false,
    "locale": "en-US",
    "valueDecimals": 2,
    "amountCurrency": "MXN",
    "amountCurrencyDisplay": "narrowSymbol",
    "amountDecimals": 2
  },
  "animation": {
    "enabled": true,
    "duration": 900,
    "easing": "easeOutQuart",
    "baseDelay": 0,
    "dataDelay": 90,
    "datasetDelay": 120
  },
  "seriesStyle": {
    "MP Prescripcion": "#9085E9",
    "MP Libre": "#E985AC",
    "PAT Controlado": "#DEE985",
    "PAT Prescripcion": "#85E9C2",
    "PAT Libre": "#D0CDEA"
  }
}

{
  "engine": "chartjs",
  "chart": {
    "type": "bar",
    "stacked": true,
    "responsive": true,
    "maintainAspectRatio": false
  },
  "mapping": {
    "labelId": "LabelID",
    "labelTitle": "LabelTitle",
    "seriesId": "SeriesID",
    "seriesTitle": "SeriesTitle",
    "valueField": "Value1",
    "amountField": "Value2"
  },
  "sorting": {
    "labelsBy": "LabelID",
    "seriesBy": "SeriesID"
  },
  "axes": {
    "xTitle": "Estatus",
    "yTitle": "Unidades",
    "yBeginAtZero": true,
    "yDecimals": 0
  },
  "tooltip": {
    "showAmount": true,
    "amountCurrency": "MXN",
    "amountDecimals": 2
  },
  "seriesStyle": {
    "MP Prescripción": "#1D4ED8",
    "MP Libre": "#2563EB",
    "PAT Controlado": "#F59E0B",
    "PAT Prescripción": "#EF4444",
    "PAT Libre": "#10B981"
  }
}
